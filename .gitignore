# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.coverage
htmlcov/

# Runtime state, data & secrets — never commit (see plan/design.md §13)
/state/
/data/
# Ignore everything inside any secrets/ dir EXCEPT committed templates (.example). The
# directory itself stays tracked so the template can live there (a whole-dir ignore would
# block re-including files inside it).
**/secrets/*
!**/secrets/*.example
.env
*.env
!*.env.example
*.sqlite
*.sqlite-*
*.parquet
token*.json
# TLS cert/key material (OAuth loopback callback M1.5, Caddy/web M7)
*.pem
*.key
*.crt
*.p12
*.pfx

# OS / editor
.DS_Store
.idea/
.vscode/
