# Template for the trader's runtime secrets (design §13). Copy to secrets/.env (gitignored)
# and fill in. NEVER commit the real file or paste these values anywhere.

# --- Schwab API (required for paper/live: live quotes + orders) ---
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=

# --- Alerting channels (optional; design §12). A channel is enabled only if its creds are set. ---
# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Email (SMTP); port 465 => implicit TLS, 587 => STARTTLS
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
